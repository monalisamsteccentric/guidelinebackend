{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@pattern-shift/shared": [
        "packages/shared/src"
      ],
      "@pattern-shift/shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}
