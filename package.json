{
  "name": "pattern-shift",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "expo": "54.0.33",
    "expo-router": "6.0.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0"
  },
  "scripts": {
    "mobile": "npm --workspace @pattern-shift/mobile run start",
    "server": "npm --workspace @pattern-shift/server run dev",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
